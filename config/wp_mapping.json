{
    "replace_rules": [
        {
            "pattern": "^\\*\\*AG\\*\\*: (.*)$",
            "replacement": "[AG_ballon_left]$1[/AG_ballon_left]"
        },
        {
            "pattern": "^\\*\\*STONE\\*\\*: (.*)$",
            "replacement": "[Stone_ballon_right]$1[/Stone_ballon_right]"
        },
        {
            "pattern": "^\\[Conversation: .*\\]$",
            "replacement": ""
        },
        {
            "pattern": "^\\[AG's Explanation: .*\\]$",
            "replacement": ""
        },
        {
            "pattern": "^\\[Image: (.*)\\]",
            "replacement": "<!-- wp:image --><figure class='wp-block-image'><img src='./images/$1' alt='$1'/></figure><!-- /wp:image -->"
        },
        {
            "pattern": "^\\[Code: Insert (.*)\\.py( Part \\d+)?\\]$",
            "replacement": ""
        }
    ],
    "amazon_style": {
        "prefix": "<div class='ag-recommend'>",
        "suffix": "</div>"
    }
}