{
    "replace_rules": [
        {
            "pattern": "^> \\*\\*AG先生\\*\\*: 「(.*)」$",
            "replacement": "<div class='ag-balloon'><p class='name'>AG先生</p><p class='text'>$1</p></div>"
        },
        {
            "pattern": "^> \\*\\*STONE\\*\\*: 「(.*)」$",
            "replacement": "<div class='stone-balloon'><p class='name'>STONE</p><p class='text'>$1</p></div>"
        },
        {
            "pattern": "\\[Image: (.*)\\]",
            "replacement": "<!-- wp:image --><figure class='wp-block-image'><img src='./images/$1' alt='$1'/></figure><!-- /wp:image -->"
        }
    ],
    "amazon_style": {
        "prefix": "<div class='ag-recommend'>",
        "suffix": "</div>"
    }
}